{
  "description": "bash-blacklist: block bash command prefixes listed in CLAUDE_BASH_BLACKLIST.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/src/bash_blacklist.py\""
          }
        ]
      }
    ]
  }
}
