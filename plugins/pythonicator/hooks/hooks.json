{
  "description": "pythonicator: enforce the Python canon's mechanical rules on every .py edit.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/check_edit.py\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
